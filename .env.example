# Database
DATABASE_URL=postgresql+psycopg://tieout_user:tieout_password@localhost:5433/tieout

# Seed Generator Config
SEED=42
NUM_GROUPS=25
NUM_MEMBERS=8000
NUM_DAYS=90

# Exception mix — proportions of BANK EVENTS (must sum to ~1.0).
# many_to_one is structural (one bank event per payment batch); its proportion
# here is the reporting target only, not used for random assignment.
EXCEPTION_MIX_CLEAN=0.30
EXCEPTION_MIX_TIMING=0.05
EXCEPTION_MIX_MANY_TO_ONE=0.40
EXCEPTION_MIX_ONE_TO_MANY=0.05
EXCEPTION_MIX_REVERSAL=0.05
EXCEPTION_MIX_SHORT_OVER_FUNDING=0.05
EXCEPTION_MIX_UNREFERENCED_INBOUND=0.05
EXCEPTION_MIX_BANK_ONLY_NOISE=0.05

# Minimum bank events guaranteed per non-clean, non-many_to_one exception type
EXCEPTION_FLOOR=10

# Probability a group-month generates a stop-loss reimbursement event
STOP_LOSS_REIMB_PROB=0.15
